# Copy this file to `.env.test`. Used by the Jest test run so tests never touch
# your development database.

NODE_ENV=test
PORT=4001

# Points at a SEPARATE database from dev. Create it once with:
#   docker exec -it url-shortner-db psql -U user -d url_shortner_dev -c 'CREATE DATABASE url_shortner_test;'
DATABASE_URL=postgresql://user:password@localhost:5432/url_shortner_test

JWT_ACCESS_SECRET=test-access-secret
JWT_REFRESH_SECRET=test-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:4001
COOKIE_SECURE=false
IP_HASH_SALT=test-ip-salt

RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=100

# SQS publishing is mocked in tests (see tests/integration/links.routes.test.ts),
# so this just needs to satisfy zod validation, not point at a real queue.
AWS_REGION=eu-west-2
CLICK_EVENTS_QUEUE_URL=https://sqs.eu-west-2.amazonaws.com/000000000000/test-click-events

# Local Redis, e.g. `docker run -p 6379:6379 redis:7-alpine`.
REDIS_URL=redis://localhost:6379
