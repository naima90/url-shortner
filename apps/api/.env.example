# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Environment: development | test | production
NODE_ENV=development

# Port the API listens on
PORT=4000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/url_shortner_dev

# JWT secrets. Use long random strings in production (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# The web app origin, used for the CORS allowlist.
CORS_ORIGIN=http://localhost:3000

# Public base URL of this API, used to build the full short link shown to users.
PUBLIC_BASE_URL=http://localhost:4000

# Set true in production (requires HTTPS) so the session cookie is Secure.
COOKIE_SECURE=false

# Salt used when hashing visitor IPs for click analytics.
IP_HASH_SALT=change-me-ip-salt

# Rate limiting for auth endpoints
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
