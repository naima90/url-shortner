{
  "name": "@url-shortner/worker",
  "version": "0.1.0",
  "private": true,
  "description": "SQS consumer that records click events for the URL shortener (application tier).",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "dotenv -e .env.test -- jest --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.699.0",
    "@url-shortner/db": "*",
    "dotenv": "^16.4.7",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "dotenv-cli": "^8.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
