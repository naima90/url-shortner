# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Environment: development | test | production
NODE_ENV=development

# Same Postgres database as apps/api (shared schema via @url-shortner/db).
DATABASE_URL=postgresql://user:password@localhost:5432/url_shortner_dev

# AWS region and the SQS queue this worker consumes (same queue apps/api publishes to).
AWS_REGION=eu-west-2
CLICK_EVENTS_QUEUE_URL=https://sqs.eu-west-2.amazonaws.com/000000000000/click-events
